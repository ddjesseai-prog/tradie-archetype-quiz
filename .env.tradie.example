# Tradie Quiz - Environment Configuration
# Copy to .env.tradie and fill in values

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=                  # MySQL connection (optional - uses SQLite locally)

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=                # Resend API key for sending emails
RESEND_FROM_EMAIL=             # From email (default: Tradie Quiz <onboarding@resend.dev>)

# ─── AWS S3 (optional) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ─── JWT/Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=

# ─── OAuth (optional) ──────────────────────────────────────────────────────
OAUTH_SERVER_URL=

# ─── Notification (optional) ───────────────────────────────────────────────
TRADIE_NOTIFICATION_WEBHOOK=   # Webhook URL for lead alerts

# ─── Bridge (future) ───────────────────────────────────────────────────────
# Leave empty - DreamDealer bridge will be added later
# DREAMDEALER_BRIDGE_QUEUE=     # Path to bridge queue for cross-system handoff